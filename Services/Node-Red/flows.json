    {
        "id": "e172632d87cd5350",
        "type": "function",
        "z": "da4a55b3415a9144",
        "name": "MongoDBPayload",
        "func": "let sensor_id = msg.topic.split(\"/\")[3];\nlet datalist = msg.payload.data;\nlet data_payload = {};\n\nfor (let index = 0; index < datalist.length; index++) {\n    data_payload[Object.keys(datalist[index])] = Object.values(datalist[index])[0];\n}\n\n\nlet sensedAt = new Date().getTime();\nlet msg_body = {\n    sensorID : sensor_id,\n    data : data_payload,\n    timestamp : sensedAt\n}\nreturn { payload: msg_body};",
        "outputs": 1,
