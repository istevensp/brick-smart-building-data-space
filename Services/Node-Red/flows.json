    {
        "id": "37795a987e606eb1",
        "type": "function",
        "z": "da4a55b3415a9144",
        "name": "function 2",
        "func": "var test = msg.payload;\n\n// Define los campos con datos del array 'test.data'\nvar fields = {\n    pressure: test.data[0].pressure,\n    temperature: test.data[1].temperature,\n    humidity: test.data[2].humidity,\n    altitude: test.data[3].altitude,\n    precipitation: test.data[4].precipitation,\n    velocity: test.data[5].velocity,\n    direction: test.data[6].direction\n};\n\n// Construye el cuerpo de la solicitud HTTP\nvar http_body = {\n    id: '66cf5b6afb392de5096ea84d',\n    data: [\n        { val: fields.pressure, type: 'atmospheric-pressure' },\n        { val: fields.temperature, type: 'temp' },\n        { val: fields.humidity, type: 'humidity' },\n        { val: fields.altitude, type: 'altitude' },\n        { val: fields.precipitation, type: 'precipitation' },\n        { val: fields.velocity, type: 'air-velocity' },\n        { val: fields.direction, type: 'wind-direction' }\n    ],\n    sensedAt: \"\" // Puedes agregar un timestamp aquí si es necesario\n};\n\n// Asigna el objeto `http_body` a `msg.payload`\nmsg.payload = http_body;\n\n// Devuelve el mensaje\nreturn msg;\n",
