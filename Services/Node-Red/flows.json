        "id": "22e63d009b5980a4",
        "type": "function",
        "z": "da4a55b3415a9144",
        "name": "function 1",
        "func": "// Obtén el payload del mensaje\nvar test = msg.payload;\n\n// Obtén el timestamp actual en formato epoch time\nvar timestamp = new Date().getTime();\n\n// Define los campos con datos del array 'test.data' y agrega el timestamp\nvar fields = {\n    pressure: test.data[0].pressure,\n    temperature: test.data[1].temperature,\n    humidity: test.data[2].humidity,\n    altitude: test.data[3].altitude,\n    precipitation: test.data[4].precipitation,\n    velocity: test.data[5].velocity,\n    direction: test.data[6].direction,\n\n    \n    timestamp: timestamp // Agrega el timestamp como un campo adicional\n};\n\n// Asigna el objeto 'fields' al payload del mensaje\nmsg.payload = fields;\n\n// Devuelve el mensaje\nreturn msg;\n",
